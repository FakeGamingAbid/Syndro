<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Syndro is a local-network-only app. No external server traffic exists.
         Cleartext HTTP is allowed at base level for direct device-to-device transfers. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
